{
  "name": "@debugmcp/adapter-dotnet",
  "version": "0.20.0",
  "description": ".NET/C# debug adapter for MCP debugger using netcoredbg",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "tools"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:ci": "tsc -b -f",
    "clean": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@debugmcp/shared": "workspace:*",
    "@vscode/debugprotocol": "^1.68.0",
    "which": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/which": "^3.0.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@debugmcp/shared": "0.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debugmcp/mcp-debugger.git",
    "directory": "packages/adapter-dotnet"
  },
  "publishConfig": {
    "access": "public"
  }
